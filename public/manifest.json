{
  "manifest_version": 3,
  "name": "Start Page Manager",
  "version": "0.1.0",
  "description": "Minimalist, customizable new tab start page.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
