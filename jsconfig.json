{
    "compilerOptions": {
        "target": "ES2024",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "checkJs": true,
        "allowJs": true,
        "noImplicitAny": false,
        "strict": false,
        "types": ["chrome"],
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src", "src/layout"],
    "exclude": ["node_modules", "dist"]
}